[Unit]
Description=SonicCity Flask application
After=network.target

[Service]
User=soniccity
Group=www-data
WorkingDirectory=/var/www/soniccity.app
EnvironmentFile=/var/www/soniccity.app/.env
ExecStart=/var/www/soniccity.app/.venv/bin/gunicorn --workers 3 --threads 2 --timeout 180 --bind 127.0.0.1:8011 wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
