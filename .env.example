APP_ENV=production
SECRET_KEY=change-me-to-a-long-random-value
SITE_DOMAIN=soniccity.app
SITE_URL=https://soniccity.app
APP_URL=https://soniccity.app

ADMIN_EMAIL=kozachenko.vitaliy@gmail.com
ADMIN_PASSWORD_HASH=generate-with-werkzeug
ADMIN_BASIC_AUTH_ENABLED=0

CONTACT_EMAIL=info@soniccity.app
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=info@soniccity.app
REQUIRE_SMTP_FOR_EMAIL=1

OPENAI_API_KEY=
OPENAI_REWRITE_MODEL=gpt-5-mini
OPENAI_TRANSLATE_MODEL=gpt-5-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts

AUDIO_STORAGE_PATH=static/audio
AUDIO_BUILD_SOURCE_MODE=en-master
AUDIO_BUILD_USE_REWRITE=1
AUDIO_BUILD_WEB_WORKERS=8
AUDIO_BUILD_EDGE_CONCURRENCY=6
AUDIO_BUILD_CHUNK_CHARS=1800
AUDIO_BUILD_EDGE_RATE=-6%
AUDIO_BUILD_EDGE_PITCH=+1Hz
AUDIO_BUILD_EDGE_VOLUME=+0%
MAX_AUDIO_UPLOAD_BYTES=52428800
MAX_MEDIA_UPLOAD_BYTES=10485760

GLOBAL_NOINDEX=1
